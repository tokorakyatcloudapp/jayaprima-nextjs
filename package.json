{
  "name": "jayaprima-nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run format && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --check --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "jose": "^6.2.2",
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --check --write",
      "eslint --fix"
